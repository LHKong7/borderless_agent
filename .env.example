# OpenAI API (required for TypeScript/OpenAI version)
OPENAI_API_KEY=sk-...
# Optional: model override (default: gpt-4o)
# MODEL_ID=gpt-4o

# Python agent: Anthropic (optional)
# ANTHROPIC_BASE_URL=...
# MODEL_ID=claude-sonnet-4-5-20250929

# Long-term memory (Python agent)
# AGENT_MEMORY=1          # set to 0 to disable
# AGENT_MEMORY_DIR=       # default: <workspace>/data/memory

# Storage backend: file (default) or cloud (S3-compatible)
# AGENT_STORAGE_BACKEND=file
# For cloud: set AGENT_STORAGE_BUCKET; optional AGENT_S3_ENDPOINT, AGENT_STORAGE_REGION
# Credentials: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY or IAM

# Context and logging
# AGENT_CONTEXT=1         # set to 0 to disable context management
# AGENT_VERBOSE=1         # set to 1 for DEBUG logging (includes structured logs)
# AGENT_REPLY_CACHE=1     # set to 1 to enable exact-match reply cache
# AGENT_API_TIMEOUT=120   # API request timeout in seconds (default: 120)
# AGENT_SUMMARIZER=1      # set to 1 to use model-based summarization
# AGENT_STREAM=1          # set to 1 to stream LLM output token-by-token
