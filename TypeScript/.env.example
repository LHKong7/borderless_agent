# ── LLM ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# MODEL_ID=gpt-4o
# OPENAI_BASE_URL=

# ── Agent behaviour ──────────────────────────────────
# AGENT_STREAM=0          # 1 = stream tokens
# AGENT_MEMORY=1          # 0 = disable long-term memory
# AGENT_CONTEXT=1         # 0 = disable context management
# AGENT_VERBOSE=0         # 1 = debug logging
# AGENT_API_TIMEOUT=120   # seconds per LLM request
# AGENT_MAX_OUTPUT_TOKENS= # override max output tokens

# ── Storage backend ──────────────────────────────────
# AGENT_STORAGE_BACKEND=file   # file | cloud
# AGENT_SESSION_DIR=           # default: ./data/sessions
# AGENT_MEMORY_DIR=            # default: ./data/memory
# AGENT_SKILLS_DIR=            # default: ./skills
# AGENT_CONTEXT_DIR=           # default: ./data/context

# ── Cloud storage (S3) ───────────────────────────────
# AGENT_STORAGE_BUCKET=
# AGENT_S3_ENDPOINT=
# AGENT_STORAGE_REGION=us-east-1

# ── Server ────────────────────────────────────────────
# PORT=8000
